<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ControleMateriais.Desktop.Views.ReciboSucessoDialog"
        Title="Recibo gerado"
        Width="460" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Border Padding="36,32" Background="{DynamicResource Brush.Surface}">
    <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center">

      <!-- Ícone de check -->
      <TextBlock Text="✔"
                 FontSize="48"
                 FontWeight="Bold"
                 Foreground="#4CAF50"
                 HorizontalAlignment="Center"/>

      <!-- Mensagem principal -->
      <TextBlock Text="Recibo gerado com sucesso!"
                 FontSize="15"
                 FontWeight="Bold"
                 Foreground="#4CAF50"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>

      <!-- Nome do arquivo -->
      <TextBlock x:Name="NomeArquivoText"
                 FontSize="12"
                 Foreground="{DynamicResource Brush.TextSecondary}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"/>

      <!-- Status em tempo real (sincronização) -->
      <TextBlock x:Name="StatusText"
                 FontSize="12"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 IsVisible="False"/>

      <!-- Botões -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,8,0,0">
        <Button x:Name="AbrirPdfBtn"
                Content="📄 Abrir PDF"
                Width="130"
                Classes="primary"
                Click="AbrirPdf_Click"/>
        <Button x:Name="NovoReciboBtn"
                Content="+ Novo Recibo"
                Width="130"
                Click="NovoRecibo_Click"/>
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
