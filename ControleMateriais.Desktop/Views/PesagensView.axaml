<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ControleMateriais.Desktop.ViewModels"
             xmlns:conv="using:ControleMateriais.Desktop.Converters"
             x:Class="ControleMateriais.Desktop.Views.PesagensView"
             x:DataType="vm:PesagensViewModel">

  <UserControl.Resources>
    <conv:BoolToBrushConverter x:Key="SyncStatusBrush"
                               TrueBrush="#4CAF50"
                               FalseBrush="#F44336"/>
    <conv:StatusPesagemBrushConverter x:Key="StatusCorBrush"/>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Button.filtro">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="14,5"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.filtro:pointerover">
      <Setter Property="Background" Value="#22FFFFFF"/>
    </Style>
    <Style Selector="Button.filtro.ativo">
      <Setter Property="Background" Value="#22FFFFFF"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>
  </UserControl.Styles>

  <Border Background="{DynamicResource Brush.SurfaceAlt}"
          BorderBrush="{DynamicResource Brush.Border}"
          BorderThickness="1" CornerRadius="10" Padding="16">
    <Grid RowDefinitions="Auto,Auto,Auto,*">

      <!-- Cabeçalho -->
      <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,10">
        <Button Grid.Column="0"
                Content="← Início"
                HorizontalAlignment="Left"
                Command="{Binding VoltarCommand}"/>

        <TextBlock Grid.Column="1"
                   Text="Pesagens"
                   Classes="h1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <Button Grid.Column="2"
                Content="+ Novo"
                Classes="primary"
                HorizontalAlignment="Right"
                Margin="0,0,8,0"
                Command="{Binding CriarNovoCommand}"
                ToolTip.Tip="Criar recibo do zero sem pesagem"/>

        <Button Grid.Column="3"
                Content="⟳ Sincronizar"
                HorizontalAlignment="Right"
                IsEnabled="{Binding !Sincronizando}"
                Command="{Binding SincronizarCommand}"
                ToolTip.Tip="Sincronizar com repositório GitHub"/>
      </Grid>

      <!-- Filtros de status -->
      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="6"
                  Margin="0,0,0,8">
        <Button Classes="filtro"
                Content="Todos"
                Tag="todos"
                Click="FiltroButton_Click"/>
        <Button Classes="filtro"
                Content="pendente"
                Tag="pendente"
                Foreground="#FF9800"
                Click="FiltroButton_Click"/>
        <Button Classes="filtro"
                Content="concluido"
                Tag="concluido"
                Foreground="#4CAF50"
                Click="FiltroButton_Click"/>
        <Button Classes="filtro"
                Content="falhou"
                Tag="falhou"
                Foreground="#F44336"
                Click="FiltroButton_Click"/>
      </StackPanel>

      <!-- Status de sincronização -->
      <TextBlock Grid.Row="2"
                 Text="{Binding Status}"
                 IsVisible="{Binding StatusVisivel}"
                 HorizontalAlignment="Center"
                 FontSize="12"
                 Margin="0,0,0,8"
                 Foreground="{Binding StatusOk, Converter={StaticResource SyncStatusBrush}}"/>

      <!-- Corpo -->
      <Grid Grid.Row="3">

        <!-- Sem repositório local -->
        <StackPanel IsVisible="{Binding !RepoPresenteLocal}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
          <TextBlock Text="Repositório não sincronizado neste computador."
                     HorizontalAlignment="Center"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     FontSize="13"/>
          <Button Content="⟳ Sincronizar agora"
                  HorizontalAlignment="Center"
                  IsEnabled="{Binding !Sincronizando}"
                  Command="{Binding SincronizarCommand}"/>
        </StackPanel>

        <!-- Repositório presente mas lista filtrada vazia -->
        <TextBlock IsVisible="{Binding ListaVazia}"
                   Text="Nenhuma pesagem encontrada para este filtro."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource Brush.TextSecondary}"
                   FontSize="13"/>

        <!-- Lista -->
        <Border IsVisible="{Binding RepoPresenteLocal}"
                Background="{DynamicResource Brush.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1" CornerRadius="8" Padding="8">
          <Grid RowDefinitions="Auto,*">

            <!-- Cabeçalho da tabela -->
            <Grid Grid.Row="0" ColumnDefinitions="*,200,130" Margin="12,4,12,6">
              <TextBlock Grid.Column="0" Text="Cliente" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextPrimary}"/>
              <TextBlock Grid.Column="1" Text="Data" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextPrimary}"/>
              <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold"
                         Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Linhas clicáveis -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding PesagensFiltradas}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PesagemItem">
                    <Border BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="0,6"
                            Cursor="Hand"
                            PointerPressed="PesagemRow_PointerPressed">
                      <Border.Styles>
                        <Style Selector="Border:pointerover">
                          <Setter Property="Background" Value="#22FFFFFF"/>
                        </Style>
                      </Border.Styles>
                      <Grid ColumnDefinitions="*,200,130" Margin="12,2">

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Cliente}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="White"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding Horario}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="White"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding StatusPesagem}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Foreground="{Binding StatusPesagem, Converter={StaticResource StatusCorBrush}}"/>

                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

          </Grid>
        </Border>

      </Grid>

    </Grid>
  </Border>

</UserControl>
