<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ControleMateriais.Desktop.ViewModels"
        x:Class="ControleMateriais.Desktop.Views.GitHubConfigDialog"
        x:DataType="vm:GitHubConfigViewModel"
        Title="Configuração de envio ao GitHub"
        Width="500" Height="580"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Border Padding="28,20,28,20" Background="{DynamicResource Brush.Surface}">
    <Grid RowDefinitions="Auto,*,Auto">

      <!-- Título + botão ajuda -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Configuração de envio ao GitHub"
                     FontSize="15" FontWeight="Bold"
                     Foreground="{DynamicResource Brush.TextPrimary}"/>
          <TextBlock TextWrapping="Wrap" FontSize="11"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Text="Informe o token, seus dados de identidade e as URLs dos repositórios do GitHub."/>
        </StackPanel>
        <Button Grid.Column="1"
                Content="?"
                Width="32" Height="32"
                VerticalAlignment="Top"
                FontWeight="Bold"
                Click="Ajuda_Click"
                ToolTip.Tip="Como obter essas informações"/>
      </Grid>

      <!-- Campos com scroll -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14">

          <!-- Token -->
          <StackPanel Spacing="4">
            <TextBlock Text="Personal Access Token *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding Token, Mode=TwoWay}"
                     PasswordChar="●"
                     Watermark="ghp_xxxxxxxxxxxxxxxxxxxx"
                     FontSize="12"/>
          </StackPanel>

          <!-- Usuário git -->
          <StackPanel Spacing="4">
            <TextBlock Text="Usuário (nome para commits) *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding GitUsuario, Mode=TwoWay}"
                     Watermark="Ex: João Silva"
                     FontSize="12"/>
          </StackPanel>

          <!-- Email git -->
          <StackPanel Spacing="4">
            <TextBlock Text="E-mail (associado ao GitHub) *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding GitEmail, Mode=TwoWay}"
                     Watermark="Ex: joao@empresa.com"
                     FontSize="12"/>
          </StackPanel>

          <!-- Separador -->
          <Border Height="1" Background="{DynamicResource Brush.Border}" Margin="0,2,0,2"/>

          <!-- URL Pesagens -->
          <StackPanel Spacing="4">
            <TextBlock Text="URL Repositório de Pesagens *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding UrlPesagens, Mode=TwoWay}"
                     Watermark="https://github.com/usuario/Pesagens.git"
                     FontSize="12"/>
          </StackPanel>

          <!-- URL Recibos -->
          <StackPanel Spacing="4">
            <TextBlock Text="URL Repositório de Recibos *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding UrlRecibos, Mode=TwoWay}"
                     Watermark="https://github.com/usuario/Recibos.git"
                     FontSize="12"/>
          </StackPanel>

          <!-- URL Tabela de Preços -->
          <StackPanel Spacing="4">
            <TextBlock Text="URL Repositório de Tabela de Preços *" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding UrlTabelaPrecos, Mode=TwoWay}"
                     Watermark="https://github.com/usuario/TabelaPrecos.git"
                     FontSize="12"/>
          </StackPanel>

          <!-- URL Banco de Dados -->
          <StackPanel Spacing="4">
            <TextBlock Text="URL Repositório de Banco de Dados (opcional)" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBox Text="{Binding UrlBancoDados, Mode=TwoWay}"
                     Watermark="https://github.com/usuario/BancoDados.git"
                     FontSize="12"/>
          </StackPanel>

          <TextBlock Text="* Campos obrigatórios" FontSize="10"
                     Foreground="{DynamicResource Brush.TextSecondary}"
                     Margin="0,2,0,0"/>

        </StackPanel>
      </ScrollViewer>

      <!-- Botões -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
        <Button Content="Cancelar" Click="Cancelar_Click" Width="90"/>
        <Button Content="Salvar"
                Click="Salvar_Click"
                IsEnabled="{Binding PodeSalvar}"
                Classes="accent"
                Width="90"/>
      </StackPanel>

    </Grid>
  </Border>

</Window>
