<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ControleMateriais.Desktop.Views.SplashWindow"
        Width="560" Height="620"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        Icon="avares://ControleMateriais.Desktop/Assets/avalonia-logo.ico">

    <!-- Fundo escuro da janela -->
    <Border Background="#1A1A2E"
            CornerRadius="0">

        <!-- Card centralizado com borda roxa -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E2E"
                    BorderBrush="#7C3AED"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="48,44"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="420">

                <StackPanel Spacing="0" HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Image Source="avares://ControleMateriais.Desktop/Assets/lfb-logo.png"
                           Width="200" Height="200"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                    <!-- Bem-vindo -->
                    <TextBlock Text="Bem-vindo!"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Subtítulo -->
                    <TextBlock Text="LFB Reciclagem Eletrônica"
                               FontSize="14"
                               Foreground="#A0A0C0"
                               HorizontalAlignment="Center"/>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
