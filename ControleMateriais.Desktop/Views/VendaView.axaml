<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ControleMateriais.Desktop.ViewModels"
             x:Class="ControleMateriais.Desktop.Views.VendaView"
             x:DataType="vm:VendaViewModel">

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

    <!-- Cabeçalho -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
      <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <TextBlock Text="&#x1F4B0;"
                   FontSize="22" VerticalAlignment="Center"/>
        <TextBlock Text="Nova Venda de Estoque"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource Brush.TextPrimary}"
                   VerticalAlignment="Center"/>
      </StackPanel>
      <Button Grid.Column="2"
              Content="&#8592; Voltar"
              Command="{Binding VoltarCommand}"
              VerticalAlignment="Center"/>
    </Grid>

    <!-- Campos: Cliente + Valor da Venda + Peso Total -->
    <Border Grid.Row="1"
            Background="{DynamicResource Brush.SurfaceAlt}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1" CornerRadius="10" Padding="20,14"
            Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,32,*,32,*">

        <StackPanel Grid.Column="0" Spacing="6">
          <TextBlock Text="Nome do Cliente" FontSize="11"
                     Foreground="{DynamicResource Brush.TextSecondary}"/>
          <TextBox Text="{Binding NomeCliente}"
                   Watermark="Nome do cliente..."
                   FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Spacing="6">
          <TextBlock Text="Valor da Venda (R$)" FontSize="11"
                     Foreground="{DynamicResource Brush.TextSecondary}"/>
          <TextBox Text="{Binding ValorVendaTexto}"
                   Watermark="R$ 0,00"
                   FontSize="14"
                   GotFocus="ValorGotFocus"
                   LostFocus="ValorLostFocus"
                   KeyDown="ValorKeyDown"/>
        </StackPanel>

        <Border Grid.Column="4"
                Background="#0F4CAF50"
                BorderBrush="#334CAF50"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,10"
                VerticalAlignment="Stretch">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
            <TextBlock Text="PESO TOTAL"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.TextSecondary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding PesoTotalStr}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#4CAF50"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- Status -->
    <TextBlock Grid.Row="2"
               Text="{Binding Status}"
               IsVisible="{Binding StatusVisivel}"
               HorizontalAlignment="Center"
               FontSize="12"
               Foreground="#4CAF50"
               Margin="0,0,0,8"/>

    <!-- Tabela de itens -->
    <Border Grid.Row="3"
            Background="{DynamicResource Brush.SurfaceAlt}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1" CornerRadius="10" Padding="0">
      <Grid RowDefinitions="Auto,*">

        <!-- Cabeçalho tabela -->
        <Border Grid.Row="0"
                Background="#1A3B82F6"
                CornerRadius="10,10,0,0"
                Padding="20,12">
          <Grid ColumnDefinitions="*,180">
            <TextBlock Grid.Column="0" Text="Material"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBlock Grid.Column="1" Text="Quantidade (kg)"
                       FontSize="12" FontWeight="Bold"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       HorizontalAlignment="Right"/>
          </Grid>
        </Border>

        <!-- Linhas -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <StackPanel>

            <!-- Itens do catálogo fixo -->
            <ItemsControl ItemsSource="{Binding ItensFixos}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:VendaItemWrapper">
                  <Border BorderBrush="{DynamicResource Brush.Border}"
                          BorderThickness="0,0,0,1"
                          Padding="20,6">
                    <Border.Styles>
                      <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#0A3B82F6"/>
                      </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="*,180">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Nome}"
                                 FontSize="12"
                                 Foreground="{DynamicResource Brush.TextPrimary}"
                                 VerticalAlignment="Center"/>
                      <TextBox Grid.Column="1"
                               Text="{Binding PesoTexto}"
                               FontSize="12"
                               TextAlignment="Right"
                               Width="160"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               GotFocus="PesoTextBox_GotFocus"
                               LostFocus="PesoTextBox_LostFocus"
                               KeyDown="PesoTextBox_KeyDown"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Separador + itens extras do estoque -->
            <Border IsVisible="{Binding TemItensExtras}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Margin="0,4,0,0" Padding="20,6,20,0">
              <TextBlock Text="Outros itens em estoque"
                         FontSize="11" FontWeight="SemiBold"
                         Foreground="{DynamicResource Brush.TextSecondary}"
                         Margin="0,0,0,4"/>
            </Border>

            <ItemsControl ItemsSource="{Binding ItensExtras}"
                          IsVisible="{Binding TemItensExtras}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:VendaItemWrapper">
                  <Border BorderBrush="{DynamicResource Brush.Border}"
                          BorderThickness="0,0,0,1"
                          Padding="20,6">
                    <Border.Styles>
                      <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#0A3B82F6"/>
                      </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="*,180">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Nome}"
                                 FontSize="12"
                                 Foreground="{DynamicResource Brush.TextPrimary}"
                                 VerticalAlignment="Center"/>
                      <TextBox Grid.Column="1"
                               Text="{Binding PesoTexto}"
                               FontSize="12"
                               TextAlignment="Right"
                               Width="160"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               GotFocus="PesoTextBox_GotFocus"
                               LostFocus="PesoTextBox_LostFocus"
                               KeyDown="PesoTextBox_KeyDown"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

          </StackPanel>
        </ScrollViewer>

      </Grid>
    </Border>

    <!-- Botões de ação -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="12"
                HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="Limpar"
              Command="{Binding LimparCommand}"
              IsEnabled="{Binding !Salvando}"/>
      <Button Content="&#x1F4BE; Salvar Venda"
              Command="{Binding SalvarCommand}"
              IsEnabled="{Binding !Salvando}"
              Classes="primary"
              FontWeight="Bold"/>
    </StackPanel>

  </Grid>

</UserControl>
