<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ControleMateriais.Desktop.Views.VendaSucessoDialog"
        Title="Venda registrada"
        Width="480" Height="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

  <Border Padding="36,32" Background="{DynamicResource Brush.Surface}">
    <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center">

      <TextBlock Text="✔"
                 FontSize="48" FontWeight="Bold"
                 Foreground="#4CAF50"
                 HorizontalAlignment="Center"/>

      <TextBlock Text="Recibo de venda gerado com sucesso!"
                 FontSize="15" FontWeight="Bold"
                 Foreground="#4CAF50"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"/>

      <TextBlock x:Name="NomeArquivoText"
                 FontSize="12"
                 Foreground="{DynamicResource Brush.TextSecondary}"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"/>

      <TextBlock x:Name="StatusText"
                 FontSize="12"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 IsVisible="False"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,8,0,0">
        <Button x:Name="AbrirPdfBtn"
                Content="📄 Abrir PDF"
                Width="140"
                Classes="primary"
                Click="AbrirPdf_Click"/>
        <Button x:Name="FecharBtn"
                Content="Fechar"
                Width="120"
                Click="Fechar_Click"/>
      </StackPanel>

    </StackPanel>
  </Border>

</Window>
